<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineNewStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="165dp">

    </androidx.constraintlayout.widget.Guideline>

    <TextView
        android:id="@+id/tvProcess"
        style="@style/regular_12_dark_gey_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Process"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"></TextView>

    <Spinner
        android:id="@+id/spinnerProcess"
        style="@style/spinner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/clSelectImage"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="@+id/guideLineNewStep"
        app:layout_constraintTop_toTopOf="@+id/clSelectImage" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clSelectImage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/ic_round_corner_white"
        android:padding="4dp"
        app:layout_constraintLeft_toRightOf="@+id/guideLineNewStep"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvProcess">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnChooseImage"
            style="@style/semi_bold_12_white"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:background="@drawable/ic_round_corner_button_orange"
            android:text="Selects"
            android:textAllCaps="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        </androidx.appcompat.widget.AppCompatButton>

        <TextView
            android:id="@+id/tvImageName"
            style="@style/regular_12_dark_gey_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:text="Add Image"
            app:layout_constraintBottom_toBottomOf="@+id/btnChooseImage"
            app:layout_constraintRight_toLeftOf="@+id/btnChooseImage"
            app:layout_constraintTop_toTopOf="@+id/btnChooseImage"></TextView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvDescription"
        style="@style/regular_12_dark_gey_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Description"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/clSelectImage"></TextView>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/etDescription"
        style="@style/et_new_regular_14_light_black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="top"
        android:hint="Describe the step in few words"
        android:lines="2"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvDescription" />

    <TextView
        android:id="@+id/tvIngredient"
        style="@style/regular_12_dark_gey_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Ingredient"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etDescription"></TextView>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/etSearchIngrd"
        style="@style/et_new_regular_14_light_black"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:drawableRight="@drawable/ic_search"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:hint="Search"
        android:lines="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="@+id/guideLineNewStep"
        app:layout_constraintTop_toBottomOf="@+id/tvIngredient" />

    <Spinner
        android:id="@+id/spinnerQty"
        style="@style/spinner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/etSearchIngrd"
        app:layout_constraintLeft_toRightOf="@+id/guideLineNewStep"
        app:layout_constraintRight_toLeftOf="@+id/btnAddIngrd"
        app:layout_constraintTop_toTopOf="@+id/etSearchIngrd" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddIngrd"
        style="@style/semi_bold_12_white"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:background="@drawable/ic_round_corner_button_orange"
        android:text="Add"
        app:layout_constraintBottom_toBottomOf="@+id/etSearchIngrd"
        app:layout_constraintLeft_toRightOf="@+id/spinnerQty"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etSearchIngrd" />

<!--    <androidx.recyclerview.widget.RecyclerView-->
<!--        android:id="@+id/rvIngredients"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="40dp"-->
<!--        android:layout_marginTop="10dp"-->
<!--        app:layout_constraintLeft_toLeftOf="parent"-->
<!--        app:layout_constraintRight_toRightOf="parent"-->
<!--        app:layout_constraintTop_toBottomOf="@+id/etSearchIngrd">-->

<!--    </androidx.recyclerview.widget.RecyclerView>-->

    <TextView
        android:id="@+id/tvMicrowave"
        style="@style/regular_12_dark_gey_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Microwave"
        app:layout_constraintBottom_toBottomOf="@+id/cbMicrowave"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cbMicrowave" />

    <androidx.appcompat.widget.AppCompatCheckBox
        android:id="@+id/cbMicrowave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:buttonTint="@color/orange"
        app:layout_constraintLeft_toRightOf="@+id/tvMicrowave"
        app:layout_constraintTop_toBottomOf="@+id/btnAddIngrd">

    </androidx.appcompat.widget.AppCompatCheckBox>

    <Spinner
        android:id="@+id/spinnerMicrowavePower"
        style="@style/spinner"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cbMicrowave" />

    <Spinner
        android:id="@+id/spinnerMicrowaveTime"
        style="@style/spinner"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintLeft_toRightOf="@+id/spinnerMicrowavePower"
        app:layout_constraintTop_toBottomOf="@+id/cbMicrowave" />

    <TextView
        android:id="@+id/tvInduction"
        style="@style/regular_12_dark_gey_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Induction"
        app:layout_constraintBottom_toBottomOf="@+id/cbInduction"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cbInduction"></TextView>

    <androidx.appcompat.widget.AppCompatCheckBox
        android:id="@+id/cbInduction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:buttonTint="@color/orange"
        app:layout_constraintLeft_toRightOf="@+id/tvMicrowave"
        app:layout_constraintTop_toBottomOf="@+id/spinnerMicrowavePower">

    </androidx.appcompat.widget.AppCompatCheckBox>

    <Spinner
        android:id="@+id/spinnerInductionPower"
        style="@style/spinner"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cbInduction" />

    <Spinner
        android:id="@+id/spinnerInductionTime"
        style="@style/spinner"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintLeft_toRightOf="@+id/spinnerInductionPower"
        app:layout_constraintTop_toBottomOf="@+id/cbInduction" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/etOverallStepTime"
        style="@style/et_new_regular_14_light_black"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:hint="Overall Step time"
        app:layout_constraintLeft_toRightOf="@+id/tvOverallStepTime"
        app:layout_constraintTop_toBottomOf="@+id/spinnerInductionPower" />

    <TextView
        android:id="@+id/tvOverallStepTime"
        style="@style/regular_12_dark_gey_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overall Step time"
        app:layout_constraintBottom_toBottomOf="@+id/etOverallStepTime"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etOverallStepTime"></TextView>

