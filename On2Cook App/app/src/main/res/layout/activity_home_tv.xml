            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clShareRecipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_10"
                android:background="@drawable/ic_three_round_corner_bottom_right_white"
                android:paddingHorizontal="@dimen/dp_5"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/clSetUpDevice">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnShare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    app:backgroundTint="@color/orange"
                    app:elevation="0dp"
                    app:fabCustomSize="@dimen/dp_40"
                    app:fabSize="mini"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:maxImageSize="@dimen/dp_20"
                    app:srcCompat="@drawable/ic_share"
                    app:tint="@color/white" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvShareRecipe"
                    style="@style/bold_14_dark_grey_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ic_round_corner_white"
                    android:paddingHorizontal="@dimen/dp_5"
                    android:text="@string/txt_share_recipe"
                    app:layout_constraintBottom_toBottomOf="@id/btnShare"
                    app:layout_constraintEnd_toStartOf="@id/btnShare"
                    app:layout_constraintTop_toTopOf="@id/btnShare" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>