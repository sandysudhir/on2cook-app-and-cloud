<?xml version="1.0" encoding="utf-8"?>
<layout>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/dark_grey">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolBar"
            android:layout_width="match_parent"
            android:layout_height="?actionBarSize"
            android:background="@color/dark_grey"
            android:paddingHorizontal="@dimen/dp_30"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="6dp"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgRetry"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="@dimen/dp_40"
                android:padding="6dp"
                android:src="@drawable/ic_refresh"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPageTitle"
                style="@style/regular_20_dark_gey_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/txt_device_set_up"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dividerHeight"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/tab"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_40"
            android:layout_marginHorizontal="@dimen/dp_10"
            android:layout_marginTop="@dimen/dp_5"
            android:background="@drawable/ic_round_corner_tab"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@+id/toolBar">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvRecipes"
                style="@style/bold_14_dark_grey_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/tab_blue_left"
                android:gravity="center"
                android:text="@string/txt_recipe"
                android:textColor="@color/white" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAudio"
                style="@style/bold_14_dark_grey_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/tab_round_unselected"
                android:gravity="center"
                android:paddingVertical="@dimen/dp_30"
                android:text="@string/txt_audio"
                android:textColor="@color/black" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollForRecipe"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/btnSend"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tab">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp_10"
                android:orientation="vertical">

                <co.lujun.androidtagview.TagContainerLayout
                    android:id="@+id/rvSelectedLocalRecipeTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:padding="@dimen/dp_5"
                    app:container_background_color="@color/white"
                    app:container_border_color="@color/dark_grey"
                    app:container_border_width="0dp"
                    app:container_enable_drag="false"
                    app:horizontal_interval="@dimen/dp_5"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tab"
                    app:tag_background_color="@color/dark_grey"
                    app:tag_border_color="@color/dark_grey"
                    app:tag_clickable="false"
                    app:tag_corner_radius="@dimen/dp_8"
                    app:tag_cross_color="@color/dark_grey4"
                    app:tag_cross_width="@dimen/dp_15"
                    app:tag_theme="none"
                    app:vertical_interval="@dimen/dp_5" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etLocalRecipe"
                    style="@style/et_regular_14_light_black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:hint="@string/txt_recipe"
                    android:padding="@dimen/dp_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rvSelectedRecipeTags" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLocalRecipe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/etDeviceRecipe"
                    app:spanCount="2"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_files" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollForAudio"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/btnSend"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tab">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp_10"
                android:orientation="vertical">

                <co.lujun.androidtagview.TagContainerLayout
                    android:id="@+id/rvLocalAudioTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:padding="@dimen/dp_5"
                    app:container_background_color="@color/white"
                    app:container_border_color="@color/dark_grey"
                    app:container_border_width="0dp"
                    app:container_enable_drag="false"
                    app:horizontal_interval="@dimen/dp_5"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tab"
                    app:tag_background_color="@color/dark_grey"
                    app:tag_border_color="@color/dark_grey"
                    app:tag_clickable="false"
                    app:tag_corner_radius="@dimen/dp_10"
                    app:tag_cross_color="@color/dark_grey4"
                    app:tag_cross_width="@dimen/dp_15"
                    app:tag_enable_cross="true"
                    app:tag_max_length="10"
                    app:tag_theme="none"
                    app:vertical_interval="@dimen/dp_5" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etLocalAudio"
                    style="@style/et_regular_14_light_black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:hint="@string/txt_audio"
                    android:padding="@dimen/dp_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rvSelectedRecipeTags" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLocalAudio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/etDeviceRecipe"
                    app:spanCount="2"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_files" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnUpload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_35"
            android:layout_marginBottom="@dimen/dp_20"
            android:importantForAccessibility="no"
            app:backgroundTint="@android:color/white"
            app:fabSize="auto"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/btnDeleteRight"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_upload"
            app:tint="@color/dark_grey4" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollForRecipeDelete"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/btnSendBack"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tab">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp_10"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/llSelectAllRecipe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/dp_5">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/cbSelectAllRecipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_select_all"
                        android:textColor="@color/dark_grey4"
                        android:textSize="14sp" />

                </LinearLayout>

                <co.lujun.androidtagview.TagContainerLayout
                    android:id="@+id/rvDeviceRecipeTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:padding="@dimen/dp_5"
                    app:container_background_color="@color/white"
                    app:container_border_color="@color/dark_grey"
                    app:container_border_width="0dp"
                    app:container_enable_drag="false"
                    app:horizontal_interval="@dimen/dp_5"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tab"
                    app:tag_background_color="@color/dark_grey"
                    app:tag_border_color="@color/dark_grey"
                    app:tag_clickable="false"
                    app:tag_corner_radius="@dimen/dp_10"
                    app:tag_cross_color="@color/dark_grey4"
                    app:tag_cross_width="@dimen/dp_15"
                    app:tag_enable_cross="true"
                    app:tag_max_length="10"
                    app:tag_theme="none"
                    app:vertical_interval="@dimen/dp_5" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etDeviceRecipe"
                    style="@style/et_regular_14_light_black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:hint="@string/txt_recipe"
                    android:padding="@dimen/dp_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rvSelectedRecipeTags" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDeviceRecipe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/etDeviceRecipeDelete"
                    app:spanCount="2"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_files" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollForAudioDelete"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/btnSendBack"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tab">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp_10"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/llSelectAllAudio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/dp_5">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/cbSelectAllAudio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_select_all"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                </LinearLayout>

                <co.lujun.androidtagview.TagContainerLayout
                    android:id="@+id/rvDeviceAudioTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:padding="@dimen/dp_5"
                    app:container_background_color="@color/white"
                    app:container_border_color="@color/dark_grey"
                    app:container_border_width="0dp"
                    app:container_enable_drag="false"
                    app:horizontal_interval="@dimen/dp_5"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tab"
                    app:tag_background_color="@color/dark_grey"
                    app:tag_border_color="@color/dark_grey"
                    app:tag_clickable="false"
                    app:tag_corner_radius="@dimen/dp_10"
                    app:tag_cross_color="@color/dark_grey4"
                    app:tag_cross_width="@dimen/dp_15"
                    app:tag_enable_cross="true"
                    app:tag_max_length="10"
                    app:tag_theme="none"
                    app:vertical_interval="@dimen/dp_5" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/etDeviceAudio"
                    style="@style/et_regular_14_light_black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:hint="@string/txt_device_audio"
                    android:padding="@dimen/dp_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rvSelectedRecipeTags" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDeviceAudio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/etDeviceRecipe"
                    app:spanCount="2"
                    tools:itemCount="2"
                    tools:listitem="@layout/item_files" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSend"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pageMargin"
            android:background="@drawable/ic_round_corner_button_orange_deselect"
            android:text="@string/txt_send"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintWidth_percent="0.4" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSendBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pageMargin"
            android:background="@drawable/ic_round_corner_button_orange_deselect"
            android:drawableStart="@drawable/back"
            android:drawableTint="@color/white"
            android:paddingStart="@dimen/dp_30"
            android:paddingEnd="@dimen/dp_10"
            android:text="@string/txt_send"
            android:textColor="@color/white"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintWidth_percent="0.4" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDeleteRight"
            style="@style/semi_bold_12_dark_grey_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pageMargin"
            android:background="@drawable/ic_round_corner_button_white"
            android:drawableEnd="@drawable/ic_next_page"
            android:drawableTint="@color/orange"
            android:paddingStart="@dimen/dp_30"
            android:paddingEnd="@dimen/dp_10"
            android:text="@string/txt_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintWidth_percent="0.4" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDelete"
            style="@style/semi_bold_12_dark_grey_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pageMargin"
            android:background="@drawable/ic_round_corner_button_white"
            android:text="@string/txt_delete"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintWidth_percent="0.4" />


        <androidx.constraintlayout.widget.Group
            android:id="@+id/deleteAudio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:constraint_referenced_ids="nestedScrollForAudioDelete,btnSendBack,btnDelete" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/deleteRecipe"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:constraint_referenced_ids="nestedScrollForRecipeDelete,btnSendBack,btnDelete" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/sendAudio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:constraint_referenced_ids="nestedScrollForAudio,btnDeleteRight,btnSend" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/sendRecipe"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:constraint_referenced_ids="nestedScrollForRecipe,btnDeleteRight,btnSend" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>