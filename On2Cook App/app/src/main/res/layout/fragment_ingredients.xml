<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_grey"
    tools:context=".create_recipe.IngredientsFragment">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddNewStep"
        style="@style/semi_bold_12_dark_grey_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_round_corner_button_white"
        android:text="Add Ingredients"
        android:textAllCaps="false"
        android:layout_marginVertical="10dp"
        android:layout_marginHorizontal="10dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/btnCookNow"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="15dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCookNow"
        style="@style/semi_bold_12_white"
        android:layout_marginRight="10dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_round_corner_button_orange_deselect"
        android:text="Next"
        app:layout_constraintTop_toBottomOf="@id/rvIngredients"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginVertical="10dp"
        android:textAllCaps="false"
        app:layout_constraintLeft_toRightOf="@+id/btnAddNewStep"
        app:layout_constraintRight_toRightOf="parent" />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvIngredients"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/btnCookNow"
        app:layout_constraintTop_toTopOf="parent"
        tools:itemCount="3"
        tools:listitem="@layout/item_prepare" />
</androidx.constraintlayout.widget.ConstraintLayout>
</layout>