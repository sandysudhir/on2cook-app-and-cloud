        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <declare-styleable name="SequenceLayout">
        <attr name="progressForegroundColor" format="color" />
        <attr name="progressBackgroundColor" format="color" />
    </declare-styleable>

    <declare-styleable name="SequenceStep">
        <attr name="anchor" format="string" />
        <attr name="anchorTextAppearance" format="reference" />
        <attr name="title" format="string" />
        <attr name="titleTextAppearance" format="reference" />
        <attr name="subtitle" format="string" />
        <attr name="subtitleTextAppearance" format="reference" />
        <attr name="active" format="boolean" />
        <attr name="anchorMinWidth" format="dimension" />
        <attr name="anchorMaxWidth" format="dimension" />
    </declare-styleable>

    <style name="DeviceScanDialogTheme" parent="ThemeOverlay.MaterialComponents.Dark">
        <item name="android:windowNoTitle">true</item>
